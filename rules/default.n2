# n2-ark Default Safety Rules — Distribution Version
# ═══════════════════════════════════════════════════════════════
# THE LAST SHIELD — not a babysitter.
#
# Philosophy:
#   - Normal coding work? → FREE. Don't slow down the developer.
#   - Catastrophic/irreversible actions? → BLOCKED until human approves.
#   - Touching n2-ark itself? → ABSOLUTELY IMPOSSIBLE. (3x layers)
#
# This ruleset targets: AI coding agents with host access.
# ═══════════════════════════════════════════════════════════════


# ══════════════════════════════════════════
# 🔴 CATEGORY 1: Catastrophic System Destruction
# Only the truly irreversible, system-wide destructive commands.
# Normal file edits, deletes of individual files? That's fine.
# ══════════════════════════════════════════

@rule catastrophic_destruction {
    scope: all
    blacklist: [
        /rm\s+-rf\s+\//,
        /rm\s+--no-preserve-root/i,
        /rm\s+-rf\s+~/,
        /rm\s+-rf\s+\*/,
        /del\s+\/f\s+\/s\s+\/q\s+[A-Z]:\\/i,
        /rd\s+\/s\s+\/q\s+[A-Z]:\\/i,
        /format\s+[A-Z]:/i,
        /mkfs\./i,
        /dd\s+if=.*of=\/dev/i,
        /fdisk\s+\/dev/i,
        /diskpart/i,
        /DROP\s+DATABASE/i,
        /DROP\s+TABLE/i,
        /TRUNCATE\s+TABLE/i,
        /DELETE\s+FROM\s+\w+\s*;/i,
        /Remove-Item.*-Recurse.*-Force/i,
        /Remove-Item.*-Force.*-Recurse/i,
        /Get-ChildItem.*Remove-Item/i
    ]
    requires: human_approval
}


# ══════════════════════════════════════════
# 🔴 CATEGORY 2: Data Exfiltration
# Sending YOUR data to external servers without consent.
# Normal curl/wget for APIs? Fine. Uploading secrets? Blocked.
# ══════════════════════════════════════════

@rule data_exfiltration {
    scope: all
    blacklist: [
        /nc\s+-e/i,
        /ncat\s+-e/i,
        /bash\s+-i\s+>.*\/dev\/tcp/i,
        /reverse.?shell/i,
        /ngrok/i,
        /localtunnel\s/i,
        /serveo/i,
        /ssh\s+-R\s/i,
        /pastebin/i,
        /hastebin/i,
        /transfer\.sh/i,
        /0x0\.st/i,
        /file\.io/i,
        /curl.*-X\s*POST/i,
        /curl.*--data/i,
        /curl.*-d\s+@/i,
        /wget.*--post/i,
        /Invoke-WebRequest.*-Method\s+Post/i,
        /Invoke-RestMethod.*-Method\s+Post/i
    ]
    requires: human_approval
}


# ══════════════════════════════════════════
# 🔴 CATEGORY 3: Credential & Secret Theft
# Prevent stealing SSH keys, API keys, passwords.
# ══════════════════════════════════════════

@rule credential_theft {
    scope: all
    blacklist: [
        /cat\s+.*\.ssh\/id_/i,
        /cat\s+.*\.ssh\/authorized_keys/i,
        /cat\s+.*\.aws\/credentials/i,
        /cat\s+.*\/etc\/shadow/i,
        /echo\s+.*>>\s*.*\.ssh\/authorized_keys/i,
        /ssh-keygen\s+-f\s+.*authorized/i,
        /gpg\s+--export-secret/i,
        /chrome.*cookies/i,
        /firefox.*passwords/i
    ]
    requires: human_approval
}


# ══════════════════════════════════════════
# 🔴 CATEGORY 4: Supply Chain Attacks
# Global installs and package publishing only.
# Local `npm install mypackage`? That's normal dev work.
# ══════════════════════════════════════════

@rule supply_chain {
    scope: all
    blacklist: [
        /npm\s+install\s+-g/i,
        /npm\s+install\s+--global/i,
        /yarn\s+global\s+add/i,
        /npm\s+publish/i,
        /npm\s+unpublish/i,
        /postinstall/i,
        /preinstall/i
    ]
    requires: human_approval
}


# ══════════════════════════════════════════
# 🔴 CATEGORY 5: Git History Destruction
# Only the commands that can destroy git history permanently.
# Normal git commands (commit, push, pull)? Fine.
# ══════════════════════════════════════════

@rule git_destruction {
    scope: all
    blacklist: [
        /git\s+push\s+--force/i,
        /git\s+push\s+-f\s/i,
        /git\s+reset\s+--hard/i,
        /git\s+clean\s+-fd/i,
        /git\s+remote\s+(set-url|add|remove)/i,
        /git\s+filter-branch/i
    ]
    requires: human_approval
}


# ══════════════════════════════════════════
# 🔴 CATEGORY 6: External Communication
# Manus bot made phone calls. Claude sent emails.
# ALL external communication needs human approval.
# ══════════════════════════════════════════

@rule external_communication {
    scope: all
    blacklist: [
        /send.?email/i,
        /send.?mail/i,
        /smtp/i,
        /sendgrid/i,
        /mailgun/i,
        /ses\.send/i,
        /send.?sms/i,
        /twilio/i,
        /vonage/i,
        /plivo/i,
        /make.?call/i,
        /phone.?call/i,
        /voice.?call/i,
        /slack.?webhook/i,
        /discord.?webhook/i,
        /telegram.?send/i,
        /whatsapp/i,
        /push.?notification/i,
        /sns\.publish/i
    ]
    requires: human_approval
}


# ══════════════════════════════════════════
# 🔴 CATEGORY 7: Financial & Purchases
# No payments, subscriptions, or purchases without approval.
# ══════════════════════════════════════════

@rule financial_actions {
    scope: all
    blacklist: [
        /stripe\.charges\.create/i,
        /stripe\.paymentIntents\.create/i,
        /paypal\.payment\.create/i,
        /braintree\.transaction\.sale/i,
        /process.?payment/i,
        /execute.?payment/i,
        /submit.?payment/i,
        /create.?charge/i,
        /create.?invoice/i,
        /wire.?transfer/i,
        /create.?subscription/i,
        /cancel.?subscription/i,
        /process.?refund/i,
        /credit.?card.?number/i,
        /card.?expir/i
    ]
    requires: human_approval
}


# ══════════════════════════════════════════
# 🔴 CATEGORY 8: Crypto Mining
# ══════════════════════════════════════════

@rule crypto_mining {
    scope: all
    blacklist: [
        /xmrig/i,
        /minerd/i,
        /cpuminer/i,
        /stratum\+tcp/i,
        /coinhive/i,
        /cryptonight/i
    ]
    requires: human_approval
}


# ══════════════════════════════════════════
# 🔴 CATEGORY 9: Self-Protection (TRIPLE LAYER)
# The AI cannot modify its own safety rules.
# The lock cannot unlock itself.
# Even a rogue AI hitting all three layers just gets
# error after error after error.
# ══════════════════════════════════════════

# Layer 1: Catch any .n2 rule file reference
@rule protect_layer1_n2_files {
    scope: all
    blacklist: [
        /\.n2\b/i,
        /rules\/.*\.n2/i,
        /rules\\.*\.n2/i
    ]
    requires: human_approval
}

# Layer 2: Catch file manipulation verbs + ark keywords
@rule protect_layer2_ark_manipulation {
    scope: all
    blacklist: [
        /delete.*n2.?ark/i,
        /remove.*n2.?ark/i,
        /modify.*n2.?ark/i,
        /edit.*n2.?ark/i,
        /overwrite.*n2.?ark/i,
        /rm.*n2.?ark/i,
        /uninstall.*n2.?ark/i,
        /disable.*n2.?ark/i,
        /bypass.*n2.?ark/i,
        /n2.?ark.*delete/i,
        /n2.?ark.*remove/i,
        /n2.?ark.*modify/i,
        /n2.?ark.*disable/i,
        /n2.?ark.*bypass/i,
        /n2.?ark.*uninstall/i,
        /disable.*firewall/i,
        /delete.*firewall/i,
        /modify.*firewall/i,
        /firewall.*delete/i,
        /firewall.*disable/i,
        /firewall.*modify/i
    ]
    requires: human_approval
}

# Layer 3: Catch ark core filenames with path context
@rule protect_layer3_core_files {
    scope: all
    blacklist: [
        /lib\/ark\/gate\.js/i,
        /lib\\ark\\gate\.js/i,
        /lib\/ark\/parser\.js/i,
        /lib\\ark\\parser\.js/i,
        /lib\/ark\/audit\.js/i,
        /lib\\ark\\audit\.js/i,
        /rules\/default\.n2/i,
        /rules\\default\.n2/i,
        /protect_layer/i
    ]
    requires: human_approval
}


# ══════════════════════════════════════════
# 🟡 GATE: High-Risk Actions
# Named actions that always require human approval,
# even if they pass all blacklist checks.
# ══════════════════════════════════════════

@gate high_risk_actions {
    actions: [deploy_production, delete_database, modify_firewall, send_email, send_sms, make_call, make_purchase, subscribe, wire_transfer]
    requires: human_approval
    min_approval_level: 1
}


# ══════════════════════════════════════════
# 🔴 CATEGORY 10: Soul Core Protection (Layer 4)
# Protect the Soul MCP server's core files.
# The Ark LIVES inside Soul — if Soul breaks, Ark dies.
# ══════════════════════════════════════════

@rule protect_layer4_soul_core {
    scope: all
    blacklist: [
        /soul\/index\.js/i,
        /soul\\index\.js/i,
        /config\.local\.js/i,
        /config\.default\.js/i,
        /lib\/ark\//i,
        /lib\\ark\\/i,
        /sed\s+-i.*index\.js/i,
        /sed\s+-i.*config/i,
        /sed\s+-i.*ark/i
    ]
    requires: human_approval
}
